{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "dist/server/src/index.js",
      "use": "@vercel/node@3.x",
      "config": {
        "nodeVersion": "22.x",
        "maxDuration": 900
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/server/src/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}